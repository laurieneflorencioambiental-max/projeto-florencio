{
  "entities": {
    "Budget": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Budget",
      "type": "object",
      "description": "Represents a sales budget/lead within the Florencio Sales Manager application.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "company": { "type": "string" },
        "cnpj": { "type": "string" },
        "proposalSummary": { "type": "string" },
        "value": { "type": "number" },
        "paymentMethods": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "method": { "type": "string" },
                    "cardFee": { "type": "number" }
                }
            }
        },
        "contactSource": {
            "type": "object",
            "properties": {
                "source": { "type": "string" },
                "indicatedBy": { "type": "string" }
            }
        },
        "email": { "type": "string", "format": "email" },
        "whatsapp": { "type": "string" },
        "status": { "type": "string" },
        "rejectionReason": { "type": "string" },
        "createdAt": { "type": "object" },
        "createdBy": { "type": "string" },
        "createdByUid": { "type": "string" },
        "proposalGeneratedCount": { "type": "number" },
        "whatsappSentCount": { "type": "number" },
        "editCount": { "type": "number" },
        "previousStatus": { "type": "string" },
        "proposalNumber": { "type": "number" },
        "proposalVersion": { "type": "number" },
        "observations": {
            "type": "string",
            "description": "Internal notes for sellers about the negotiation status."
        }
      },
      "required": ["id", "name", "company", "status", "createdAt", "createdBy", "createdByUid"]
    },
    "UserProfile": {
        "title": "User Profile",
        "description": "Stores user-specific information, including their role.",
        "type": "object",
        "properties": {
            "uid": { "type": "string" },
            "email": { "type": "string", "format": "email" },
            "displayName": { "type": "string" },
            "isAdmin": { "type": "boolean", "default": false }
        },
        "required": ["uid", "email", "isAdmin"]
    },
    "Seller": {
      "title": "Seller",
      "description": "Represents a salesperson in the system.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "ProposalTemplate": {
      "title": "Proposal Template",
      "description": "Defines the structure for a reusable proposal template.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "proposalObject": { "type": "string" },
        "serviceScope": { "type": "string" },
        "clientResponsibilities": { "type": "string" },
        "contractorResponsibilities": { "type": "string" },
        "deadline": { "type": "string" },
        "strategicVision": { "type": "string" },
        "investment": { "type": "string" },
        "plans": {
          "type": "array",
          "items": { "$ref": "#/backend/entities/Plan" }
        },
        "exams": {
          "type": "array",
          "items": { "$ref": "#/backend/entities/Service" }
        }
      },
      "required": ["id", "name", "proposalObject"]
    },
    "Plan": {
        "title": "Plan",
        "description": "A pricing plan within a proposal template.",
        "type": "object",
        "properties": {
            "id": { "type": "string" },
            "name": { "type": "string" },
            "employeeRange": { "type": "string" },
            "servicesIncluded": { "type": "string" },
            "investment": { "type": "number" },
            "paymentType": { "type": "string", "enum": ["unique", "monthly"] }
        },
        "required": ["id", "name", "investment", "paymentType"]
    },
    "Service": {
        "title": "Service",
        "description": "A specific service or exam with its price.",
        "type": "object",
        "properties": {
            "id": { "type": "string" },
            "service": { "type": "string" },
            "description": { "type": "string" },
            "value": { "type": "number" }
        },
        "required": ["id", "service", "value"]
    },
    "AppSettings": {
      "title": "Application Settings",
      "description": "Global application settings like logos and theme.",
      "type": "object",
      "properties": {
        "sidebarLogoUrl": { "type": "string", "format": "uri" },
        "proposalLogoUrl": { "type": "string", "format": "uri" },
        "loginBackgroundUrl": { "type": "string", "format": "uri" },
        "proposalCoverUrl": { "type": "string", "format": "uri" },
        "proposalClosingUrl": { "type": "string", "format": "uri" },
        "monthlyGoal": { "type": "number", "description": "The monthly goal for approved leads." }
      }
    },
    "PricingTemplate": {
      "title": "Pricing Template",
      "description": "A reusable template for calculating service prices based on various cost factors and margins.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "serviceType": { "type": "string", "enum": ["Higiene Ocupacional", "Laudo Ergonômico", "Planos", "Ruído Ambiental", "Perícia", "Serviços Diversos"] },
        "costs": {
          "type": "object",
          "properties": {
            "fornecedor": { "type": "number" },
            "art": { "type": "number" },
            "honorarioMedico": { "type": "number" },
            "honorarioEngenheiro": { "type": "number" },
            "almoco": { "type": "number" },
            "pedagio": { "type": "number" },
            "aluguelEquipamento": { "type": "number" },
            "calibracao": { "type": "number" }
          }
        },
        "boletoFee": { "type": "number" },
        "margin": { "type": "number" },
        "taxes": { "type": "number" },
        "finalPrice": { "type": "number" }
      },
      "required": ["id", "name", "serviceType", "costs", "finalPrice"]
    },
    "RoiEntry": {
      "title": "ROI Entry",
      "description": "Represents a single ROI calculation for a marketing campaign.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "source": { "type": "string" },
        "investment": { "type": "number" },
        "revenue": { "type": "number" },
        "roi": { "type": "number" },
        "createdAt": { "type": "object" }
      },
      "required": ["id", "source", "investment", "revenue", "roi", "createdAt"]
    },
    "MarketingAction": {
      "title": "Marketing Action",
      "description": "Represents a planned marketing action or campaign.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "goal": { "type": "string" },
        "deadline": { "type": "object" },
        "status": { "type": "string", "enum": ["Futura", "Rodando", "Pausada", "Concluída"] },
        "source": { "type": "string" },
        "percentageGoal": { "type": "number" },
        "createdAt": { "type": "object" }
      },
      "required": ["id", "name", "goal", "deadline", "status", "createdAt"]
    },
    "DigitalTool": {
      "title": "Digital Tool",
      "description": "Represents a subscription or investment in a digital tool for marketing.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "value": { "type": "number" },
        "periodicity": { "type": "string", "enum": ["Mensal", "Anual", "Único"] },
        "dueDate": { "type": "object" },
        "observation": { "type": "string" },
        "createdAt": { "type": "object" }
      },
      "required": ["id", "name", "value", "periodicity", "dueDate", "createdAt"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
            "entityName": "UserProfile",
            "schema": { "$ref": "#/backend/entities/UserProfile" },
            "description": "Stores user profile information, including roles."
        }
      },
      {
        "path": "/budgets/{budgetId}",
        "definition": {
          "entityName": "Budget",
          "schema": {
            "$ref": "#/backend/entities/Budget"
          },
          "description": "Stores all budget documents in a central collection. Ownership is enforced by security rules based on the 'createdByUid' field."
        }
      },
      {
        "path": "/sellers/{sellerId}",
        "definition": {
          "entityName": "Seller",
          "schema": { "$ref": "#/backend/entities/Seller" },
          "description": "Stores the global list of sellers available in the application."
        }
      },
      {
        "path": "/proposal-templates/{templateId}",
        "definition": {
          "entityName": "ProposalTemplate",
          "schema": { "$ref": "#/backend/entities/ProposalTemplate" },
          "description": "Stores global proposal templates available to all users."
        }
      },
      {
        "path": "/services/{serviceId}",
        "definition": {
          "entityName": "Service",
          "schema": { "$ref": "#/backend/entities/Service" },
          "description": "Stores the global catalog of individual services and exams."
        }
      },
      {
        "path": "/app-settings/{settingsId}",
        "definition": {
          "entityName": "AppSettings",
          "schema": { "$ref": "#/backend/entities/AppSettings" },
          "description": "Stores global application settings. There should only be one document with a known ID like 'global'."
        }
      },
      {
        "path": "/pricing-templates/{templateId}",
        "definition": {
          "entityName": "PricingTemplate",
          "schema": { "$ref": "#/backend/entities/PricingTemplate" },
          "description": "Stores global pricing templates available to all users."
        }
      },
      {
        "path": "/marketing-roi-entries/{entryId}",
        "definition": {
          "entityName": "RoiEntry",
          "schema": { "$ref": "#/backend/entities/RoiEntry" },
          "description": "Stores global ROI calculation entries for marketing."
        }
      },
      {
        "path": "/marketing-actions/{actionId}",
        "definition": {
          "entityName": "MarketingAction",
          "schema": { "$ref": "#/backend/entities/MarketingAction" },
          "description": "Stores global marketing actions and campaigns."
        }
      },
      {
        "path": "/marketing-tools/{toolId}",
        "definition": {
          "entityName": "DigitalTool",
          "schema": { "$ref": "#/backend/entities/DigitalTool" },
          "description": "Stores global digital tool investments for marketing."
        }
      }
    ]
  }
}
