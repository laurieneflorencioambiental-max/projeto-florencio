/**
 * # Core Philosophy
 * This ruleset enforces a strict user-ownership model for the Florencio Sales Manager application.
 * All user-generated data, specifically 'budgets', is exclusively owned by and accessible only to the user who created it.
 * Global data like 'sellers', 'proposal-templates', 'services', and 'app-settings' are readable by any authenticated user, but writable only by them as well (simplification for MVP).
 * The security model prioritizes data privacy and isolation for user data, while allowing collaborative management of global data. This aligns with LGPD principles by ensuring data is only accessible by authorized personnel.
 *
 * # Data Structure
 * - All budgets are stored in a central `/budgets` collection. Ownership is managed by a `createdByUid` field in each document.
 * - Global configuration data is stored in top-level collections.
 *
 * # Key Security Decisions & "Blindagem"
 * - **Field-Based Ownership**: For `/budgets/{budgetId}`, write access is determined by the `createdByUid` field matching the authenticated user's ID. This prevents any user from modifying another user's data.
 * - **Global Read for Managers**: Any authenticated user can read all budget documents. This enables the central "manager view" and analytics across all sellers. While sellers can also read all data, they are only able to modify their own, preventing unauthorized changes.
 * - **No User Listing**: There are no rules allowing clients to list documents in a top-level `/users` collection, preventing enumeration of all users in the system.
 * - **Public Proposal Read, Secure Create**: Proposals are viewable by anyone with the link (`allow get: if true`), which is required for sharing with clients. However, only authenticated users can create new ones (`allow create: if isSignedIn()`). Updates and deletes are disabled from the client to prevent tampering.
 * - **Deny by Default**: The most important rule of all. Any path or method not explicitly matched by an `allow` rule is automatically denied. This prevents accidental exposure of data.
 *
 * This comment was added to force a redeploy of the security rules.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions for Readability and Reuse
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Secures the central 'budgets' collection.
     * This allows any authenticated user (like a manager) to view all budgets,
     * but restricts creation and modification to the budget's owner.
     * @path /budgets/{budgetId}
     */
    match /budgets/{budgetId} {
      // Allow any authenticated user to read all budget documents.
      // This enables the central manager view.
      allow get, list: if isSignedIn();

      // Users can only create budgets where they are the owner.
      allow create: if isSignedIn() && request.resource.data.createdByUid == request.auth.uid;
      
      // Users can only update or delete their own budgets.
      // The `get()` call ensures the owner of the existing document is checked.
      allow update, delete: if isSignedIn() && get(/databases/$(database)/documents/budgets/$(budgetId)).data.createdByUid == request.auth.uid;
    }
    
    /**
     * @description Secures the 'proposals' collection.
     * Proposals are public to anyone with the link (for sharing with clients), but can only be
     * created by authenticated users. Updates and deletes are disallowed from the client for simplicity and security.
     * @path /proposals/{proposalId}
     */
    match /proposals/{proposalId} {
      allow get: if true; // Public read for sharing
      allow list: if false; // Disallow listing all proposals for privacy
      allow create: if isSignedIn();
      allow update, delete: if false; // Prevent modification after creation
    }

    /**
     * @description Secures the 'sellers' collection.
     * This is considered global data for the app. Any authenticated user can read and write.
     */
    match /sellers/{sellerId} {
      allow read, write: if isSignedIn();
    }
    
    /**
     * @description Secures the 'proposal-templates' collection.
     * Global data. Any authenticated user can read and write.
     */
    match /proposal-templates/{templateId} {
       allow read, write: if isSignedIn();
    }

    /**
     * @description Secures the 'services' collection.
     * Global data. Any authenticated user can read and write to the service catalog.
     */
    match /services/{serviceId} {
      allow read, write: if isSignedIn();
    }

    /**
     * @description Secures the 'app-settings' collection.
     * Any user (even unauthenticated) can read the global settings for logos and branding on the login page.
     * However, only authenticated users can write/change these settings.
     */
    match /app-settings/{settingsId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
