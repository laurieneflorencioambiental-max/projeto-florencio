/**
 * Core Philosophy: This ruleset enforces a strict user-ownership model for a CRM-style application.
 * Each user can create, read, update, and delete their own sales quotes, but cannot access
 * quotes belonging to other users. This provides strong data isolation between users.
 *
 * Data Structure: All data is stored in a single top-level collection named 'quotes'.
 * There is no hierarchical data structure; authorization is self-contained within each
 * quote document.
 *
 * Key Security Decisions:
 * - Strict Ownership: All operations (read, write, delete) are gated by an ownership check.
 * - Denormalized Owner ID: To enforce ownership, each document in the 'quotes' collection
 *   MUST have an 'ownerId' field containing the UID of the user who created it. This is a
 *   critical requirement for the security model to function.
 * - No Public Listing: Listing the entire '/quotes' collection is disallowed to prevent
 *   accidental data leakage and to ensure clients must perform targeted, authenticated queries
 *   for the data they are permitted to see.
 *
 * Denormalization for Authorization: The security model relies entirely on a denormalized
 * 'ownerId' field on each `/quotes/{quoteId}` document. This avoids costly and complex `get`
 * calls and makes the ownership check fast and efficient. The rules for creating and
 * updating documents enforce the presence and immutability of this field.
 *
 * Structural Segregation: Not applicable in this model as all data follows the same
 * private, owner-only access pattern within a single collection.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the currently authenticated user's UID matches the provided userId.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * Verifies the document exists and the user is the owner.
     * Used for safe updates and deletes.
     */
    function isExistingOwner(ownerId) {
      return resource != null && isOwner(ownerId);
    }

    /**
     * Validates that the 'ownerId' field of a new document is being set to the
     * creator's own UID. This is a critical check to establish ownership.
     * CRITICAL: This rule requires the client to send an 'ownerId' field.
     */
    function isCreatingWithOwnerId() {
      return request.resource.data.ownerId == request.auth.uid;
    }

    /**
     * Validates that the 'ownerId' field is not being changed during an update.
     * This makes ownership permanent and prevents takeovers.
     */
    function ownerIdIsImmutable() {
      return request.resource.data.ownerId == resource.data.ownerId;
    }

    // ------------------------------------------------------------------------
    // Collection Rules
    // ------------------------------------------------------------------------

    /**
     * @description Rules for the 'quotes' collection, enforcing strict ownership.
     *              Users can only manage quotes they have created.
     *              CRITICAL: This security model REQUIRES that each 'Quote' document
     *              contains an 'ownerId' field with the creator's UID.
     * @path        /quotes/{quoteId}
     * @allow       (create) A signed-in user creating a new quote with `{ ownerId: "their-uid", ... }`.
     * @deny        (get) A user trying to read a quote where `resource.data.ownerId` is not their UID.
     * @deny        (list) Any user trying to list all documents in the '/quotes' collection.
     * @principle   Enforces strict document ownership for all operations. The rules ensure
     *              that an 'ownerId' is set on creation and cannot be changed.
     */
    match /quotes/{quoteId} {
      allow get: if isOwner(resource.data.ownerId);
      allow list: if false; // Denied to prevent leaking all quotes. Clients must query with a 'where("ownerId", "==", auth.uid)' clause, which is enabled by the 'get' rule.
      allow create: if isSignedIn() && isCreatingWithOwnerId();
      allow update: if isExistingOwner(resource.data.ownerId) && ownerIdIsImmutable();
      allow delete: if isExistingOwner(resource.data.ownerId);
    }
  }
}