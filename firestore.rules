/**
 * # Firestore Security Rules: Florencio Sales Manager
 *
 * ## Core Philosophy
 * This ruleset enforces a simple, authentication-based security model. The primary goal is to ensure that only authenticated users can interact with the database. It assumes that more complex business logic, such as validating budget status transitions or user-specific permissions, is handled in a trusted server-side environment (e.g., Cloud Functions). This approach protects the data from anonymous access while providing flexibility for the trusted backend.
 *
 * ## Data Structure
 * The data structure is flat, consisting of a single top-level collection:
 * - `/budgets/{budgetId}`: Stores all budget documents for the application.
 *
 * ## Key Security Decisions
 * - **Authenticated Access Only**: All read and write operations on the `/budgets` collection are restricted to users who are signed in. Unauthenticated or anonymous access is completely denied.
 * - **No User-Specific Ownership**: The rules do not enforce document ownership because the `Budget` entity lacks an `ownerId` or `creatorId` field. This aligns with the system design where business logic is managed by a central, trusted backend rather than granting individual users direct, fine-grained control over specific documents.
 * - **Flexible Data Schema**: In this prototyping stage, the rules do not validate the specific shape or data types of the `Budget` documents. The focus is strictly on authorization (who can access the data), not on schema enforcement.
 * - **Denial of Destructive Operations on Non-Existent Documents**: Update and delete operations are explicitly denied if the target document does not already exist, preventing unintended side effects.
 *
 * ## Denormalization for Authorization
 * This principle is not applicable to the current data model, as there are no relational data dependencies that would require denormalization for security rule checks. All authorization is based solely on the user's authentication state.
 *
 * ## Structural Segregation
 * This principle is not applicable, as the application does not distinguish between public and private data. All budget data is handled within a single collection and is considered private to the application's authenticated users.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions

    /**
     * Checks if a user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Ensures a user is authenticated and the document they are modifying or deleting
     * already exists. This prevents writes to non-existent paths.
     */
    function isAuthenticatedAndResourceExists() {
      return isSignedIn() && resource != null;
    }

    /**
     * @description Allows any authenticated user to read, create, update, and delete budget documents.
     * @path        /budgets/{budgetId}
     * @allow       An authenticated user (create) a new budget document.
     * @deny        An unauthenticated user (get) a budget document.
     * @principle   Gates all access to authenticated users, assuming business logic is handled in a trusted backend environment as per system design.
     */
    match /budgets/{budgetId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAuthenticatedAndResourceExists();
      allow delete: if isAuthenticatedAndResourceExists();
    }
  }
}