/**
 * # Firestore Security Rules: Florencio Sales Manager
 *
 * ## Core Philosophy
 * This ruleset enforces a simple, authentication-based security model. The primary goal is to ensure that only authenticated users can interact with the database. It assumes that more complex business logic, such as validating budget status transitions or user-specific permissions, is handled in a trusted server-side environment (e.g., Cloud Functions). This approach protects the data from anonymous access while providing flexibility for the trusted backend.
 *
 * ## Data Structure
 * The data structure consists of several top-level collections.
 *
 * ## Key Security Decisions
 * - **Authenticated Access Mostly**: Most read and write operations are restricted to users who are signed in.
 * - **Public Read for Partnerships & Settings**: The `partnerships` and `app-settings` collections are publicly readable to allow link sharing and login page customization.
 * - **User Profile Security**: Users can only update their own profile document.
 * - **Denial of Destructive Operations on Non-Existent Documents**: Update and delete operations are explicitly denied if the target document does not already exist.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions

    /**
     * Checks if a user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }
    
    /**
     * Checks if the requesting user is the owner of the document.
     */
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    /**
     * Ensures a user is authenticated and the document they are modifying or deleting
     * already exists.
     */
    function isAuthenticatedAndResourceExists() {
      return isSignedIn() && resource != null;
    }

    /**
     * @description Budgets can be managed by any authenticated user.
     */
    match /budgets/{budgetId} {
      allow get, list, create: if isSignedIn();
      allow update, delete: if isAuthenticatedAndResourceExists();
    }

    /**
     * @description Users can read any profile, but only update their own.
     */
    match /users/{userId} {
      allow get, list, create: if isSignedIn();
      allow update: if isOwner(userId) && resource != null;
      allow delete: if false; // Disallow deleting user profiles from client
    }
    
    /**
     * @description App settings are public to read, but only authenticated users can write.
     */
    match /app-settings/{settingId} {
      allow get: if true;
      allow list, create, update: if isSignedIn();
      allow delete: if false;
    }

    /**
     * @description Proposal Templates can be managed by any authenticated user.
     */
    match /proposal-templates/{templateId} {
      allow get, list, create: if isSignedIn();
      allow update, delete: if isAuthenticatedAndResourceExists();
    }
    
    /**
     * @description Pricing Templates can be managed by any authenticated user.
     */
    match /pricing-templates/{templateId} {
      allow get, list, create: if isSignedIn();
      allow update, delete: if isAuthenticatedAndResourceExists();
    }
    
    /**
     * @description Services Catalog can be managed by any authenticated user.
     */
    match /services/{serviceId} {
      allow get, list, create: if isSignedIn();
      allow update, delete: if isAuthenticatedAndResourceExists();
    }
    
    /**
     * @description Commission Templates can be managed by any authenticated user.
     */
    match /commission-templates/{templateId} {
      allow get, list, create: if isSignedIn();
      allow update, delete: if isAuthenticatedAndResourceExists();
    }
    
    /**
     * @description Partnerships are created by authenticated users but are publicly readable via their link.
     */
    match /partnerships/{partnershipId} {
      allow get: if true;
      allow create: if isSignedIn();
      allow list, update, delete: if false;
    }
    
    /**
     * @description Marketing data can be managed by any authenticated user.
     */
    match /marketing-roi-entries/{entryId} {
      allow get, list, create: if isSignedIn();
      allow update, delete: if isAuthenticatedAndResourceExists();
    }
    match /marketing-actions/{actionId} {
      allow get, list, create: if isSignedIn();
      allow update, delete: if isAuthenticatedAndResourceExists();
    }
    match /marketing-tools/{toolId} {
      allow get, list, create: if isSignedIn();
      allow update, delete: if isAuthenticatedAndResourceExists();
    }
    
    /**
     * @description Audit logs are written by Cloud Functions and are read-only for authenticated users (admin logic in app).
     */
    match /audit-logs/{logId} {
      allow get, list: if isSignedIn();
      allow write: if false;
    }
  }
}
