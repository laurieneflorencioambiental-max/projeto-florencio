/**
 * # Core Philosophy
 * This ruleset enforces a strict user-ownership model for the Florencio Sales Manager application.
 * All user-generated data, specifically 'budgets', is exclusively owned by and accessible only to the user who created it.
 * Global data like 'sellers', 'proposal-templates', and 'app-settings' are readable by any authenticated user, but writable only by them as well (simplification for MVP).
 * The security model prioritizes data privacy and isolation for user data, while allowing collaborative management of global data.
 *
 * # Data Structure
 * - Private user data is nested under `/users/{userId}`.
 * - Global configuration data is stored in top-level collections.
 *
 * # Key Security Decisions
 * - **Path-Based Ownership**: For `/users/{userId}`, access control is determined entirely by the `{userId}` in the document path.
 * - **Global Read/Write for Authenticated Users**: For simplicity in this stage, any logged-in user can manage sellers, templates, and app settings. This can be locked down further with custom claims (e.g., admin roles) in the future.
 * - **No User Listing**: There are no rules allowing clients to list documents in the top-level `/users` collection.
 * - **Deny by Default**: Any path not explicitly matched is inaccessible.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the currently authenticated user's UID matches the provided userId from the path.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Secures the 'budgets' subcollection, ensuring users can only manage their own budget documents.
     * @path /users/{userId}/budgets/{budgetId}
     */
    match /users/{userId}/budgets/{budgetId} {
      // READ, WRITE: Only the owner can manage their own budgets.
      allow read, write: if isOwner(userId);
    }
    
    /**
     * @description Secures the 'proposals' collection.
     * Proposals are public to anyone with the link, but can only be created by authenticated users.
     * Updates and deletes are disallowed from the client for simplicity and security.
     * @path /proposals/{proposalId}
     */
    match /proposals/{proposalId} {
      allow get: if true;
      allow list: if false; // Disallow listing all proposals
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    /**
     * @description Secures the 'sellers' collection.
     * Any authenticated user can read and write.
     */
    match /sellers/{sellerId} {
      allow read, write: if isSignedIn();
    }
    
    /**
     * @description Secures the 'proposal-templates' collection.
     * Any authenticated user can read and write.
     */
    match /proposal-templates/{templateId} {
       allow read, write: if isSignedIn();
    }
  }
}
