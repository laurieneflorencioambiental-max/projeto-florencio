/**
 * # Core Philosophy
 * This ruleset enforces a strict user-ownership model for the Florencio Sales Manager application.
 * All user-generated data, specifically 'budgets', is exclusively owned by and accessible only to the user who created it.
 * The security model prioritizes data privacy and isolation, ensuring that one user can never access another user's sales data.
 *
 * # Data Structure
 * All user data is nested within a top-level 'users' collection. The hierarchical path is '/users/{userId}/budgets/{budgetId}'.
 * This structure inherently links data to its owner through the path itself, simplifying security logic and enabling secure queries.
 *
 * # Key Security Decisions
 * - **Path-Based Ownership**: Access control is determined entirely by the `{userId}` in the document path. If a user's authenticated UID matches the `{userId}`, they are granted access.
 * - **No User Listing**: There are no rules allowing clients to list documents in the top-level `/users` collection, preventing enumeration of all application users.
 * - **Deny by Default**: Any path not explicitly matched in these rules is inaccessible.
 *
 * # Denormalization for Authorization
 * The data structure is designed to be self-contained for authorization. Each user's data tree (`/users/{userId}`) contains all information needed to secure its contents. This eliminates the need for slow and costly `get()` calls to other documents for permission checks, resulting in simpler, more performant, and more secure rules.
 *
 * # Structural Segregation
 * This ruleset uses structural segregation by placing all private user data within a user-specific subcollection (`/users/{userId}/budgets`). This is the most secure and performant way to manage private user data and prevent accidental data leakage in list operations.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the currently authenticated user's UID matches the provided userId from the path.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * A robust check for update/delete operations.
     * Ensures the user is the owner AND the document already exists.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && exists(/databases/$(database)/documents/users/$(userId)/budgets/$(budgetId));
    }

    /**
     * On create, validates that the document's internal 'id' field matches its document ID in the path.
     * This enforces relational integrity from the moment of creation.
     */
    function isBudgetCreateValid(budgetId) {
      return request.resource.data.id == budgetId;
    }

    /**
     * On update, ensures the document's internal 'id' field cannot be changed.
     * This prevents re-linking or altering the fundamental identity of the document.
     */
    function isBudgetUpdateValid() {
      return request.resource.data.id == resource.data.id;
    }


    /**
     * @description Secures the 'budgets' subcollection, ensuring users can only manage their own budget documents.
     * @path /users/{userId}/budgets/{budgetId}
     */
    match /users/{userId}/budgets/{budgetId} {
      // READ, WRITE: Only the owner can manage their own budgets.
      allow read, write: if isOwner(userId);
    }
    
    /**
     * @description Secures the 'proposals' collection.
     * Proposals are public to anyone with the link, but can only be created by authenticated users.
     * Updates and deletes are disallowed from the client for simplicity and security.
     * @path /proposals/{proposalId}
     */
    match /proposals/{proposalId} {
      allow get: if true;
      allow list: if false; // Disallow listing all proposals
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    /**
     * @description Secures the 'sellers' collection.
     * Any authenticated user can read, create, update, and delete sellers.
     * This allows for collaborative management of the sales team list.
     */
    match /sellers/{sellerId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}
