rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is signed in
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Helper function to check if the requester is an admin.
    // This reads the user's own profile document to check the `isAdmin` flag.
    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Users can read their own profile. Admins can read any user's profile.
    // Users can update their own profile (e.g., display name, photo).
    match /users/{userId} {
      allow get: if request.auth.uid == userId || isAdmin();
      allow list: if isAdmin();
      allow update: if request.auth.uid == userId;
      // Creation/deletion should be handled securely, e.g., via a Cloud Function or manually.
      allow create, delete: if false;
    }

    // Budgets (Leads) can be managed by their creator or any admin.
    match /budgets/{budgetId} {
      // Users can list and read budgets. The app's queries MUST enforce filtering for non-admins.
      allow read: if isSignedIn();
      
      // A user can only create a budget with their own UID as the creator.
      allow create: if isSignedIn() && request.resource.data.createdByUid == request.auth.uid;
      
      // Only the document creator or an admin can update or delete it.
      allow update, delete: if isSignedIn() && (resource.data.createdByUid == request.auth.uid || isAdmin());
    }

    // Templates and services can be read by any authenticated user for creating proposals.
    // Only admins can create, update, or delete them.
    match /proposal-templates/{templateId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    // Pricing and commission templates are for admin use only.
    match /pricing-templates/{templateId} {
        allow read, write: if isAdmin();
    }

    match /commission-templates/{templateId} {
        allow read, write: if isAdmin();
    }
    
    // All marketing-related data is for admin use only.
    match /marketing-actions/{id}      { allow read, write: if isAdmin(); }
    match /marketing-roi-entries/{id} { allow read, write: if isAdmin(); }
    match /marketing-tools/{id}       { allow read, write: if isAdmin(); }

    // App settings need to be publicly get-able for login screen styling, but only writable by admins.
    match /app-settings/{settingId} {
      allow get: if true;
      allow write: if isAdmin();
    }

    // Generated proposals and partnership links must be publicly readable.
    // Creation is handled within the app by authenticated users.
    match /proposals/{proposalId} {
      allow get: if true;
      allow create: if isSignedIn();
    }
    
    match /partnerships/{partnershipId} {
        allow get: if true;
        allow create: if isAdmin();
    }

    // Audit logs are written by a backend function and should only be readable by admins.
    match /audit-logs/{logId} {
      allow read: if isAdmin();
      allow write: if false; 
    }
  }
}
