rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Matches any file within the /customization folder and all its subdirectories.
    // This ensures that uploads like /customization/proposal_logo are covered.
    match /customization/{allPaths=**} {

      // Allow anyone to read the customization images (logos, backgrounds).
      // This is required for them to be displayed in the app.
      allow read: if true;

      // Only allow authenticated users to write (upload, update, delete) files.
      // This is the definitive rule to prevent the permission-denied errors
      // that were causing the infinite loading.
      allow write: if request.auth != null;
    }
  }
}
