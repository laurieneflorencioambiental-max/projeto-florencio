rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Matches any file within the /customization folder and its subdirectories.
    // Using a recursive wildcard to ensure all paths are covered.
    match /customization/{allPaths=**} {

      // Anyone can read the images (logos, backgrounds).
      // This is safe because they are just visual assets.
      allow read: if true;

      // Only an authenticated user can upload, update, or delete images.
      // This prevents unauthorized users from changing the app's appearance.
      allow write: if request.auth != null;
    }
  }
}
